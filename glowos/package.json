{
  "name": "glowos",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @glowos/db db:generate",
    "db:migrate": "pnpm --filter @glowos/db db:migrate",
    "db:push": "pnpm --filter @glowos/db db:push",
    "db:studio": "pnpm --filter @glowos/db db:studio",
    "db:seed": "pnpm --filter @glowos/db db:seed"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  }
}

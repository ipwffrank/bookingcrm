DATABASE_URL=postgresql://glowos:glowos_dev@localhost:5432/glowos_dev
REDIS_URL=redis://localhost:6379

# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# HitPay
HITPAY_API_KEY=
HITPAY_SALT=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
# Comma-separated E.164 phones that have joined the WhatsApp Sandbox
# (texted "join <keyword>" to +14155238886). When TWILIO_WHATSAPP_FROM
# is the sandbox number (+14155238886), sends to phones NOT listed here
# are skipped before the API call to avoid burning the 50/day quota on
# guaranteed-failed sends. Ignored in production.
SANDBOX_JOINED_PHONES=+6596721317,+6591262212

# Anthropic
ANTHROPIC_API_KEY=

# Google Actions Center
GOOGLE_ACTIONS_CENTER_PARTNER_ID=
GOOGLE_ACTIONS_CENTER_API_KEY=

# Auth
JWT_SECRET=changeme
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d
BOOKING_TOKEN_SECRET=changeme

# App
NODE_ENV=development
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3002

# Web app – API URL used by server components (read at runtime on the server)
# and client components (inlined at build time via NEXT_PUBLIC_ prefix).
# In production (Vercel), set API_URL in the project environment variables.
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
